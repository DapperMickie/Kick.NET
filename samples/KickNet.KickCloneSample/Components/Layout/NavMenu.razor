@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

<header class="shell-header">
    <a class="brand" href="/">
        <span class="brand-mark">K</span>
        <span>Kick.NET Live</span>
    </a>
    <nav class="nav-actions">
        <a href="/" title="Browse streams">Browse</a>
        @if (HttpContextAccessor.HttpContext?.User.Identity?.IsAuthenticated == true)
        {
            <span class="user-chip" title="Signed in user">@HttpContextAccessor.HttpContext.User.FindFirstValue(ClaimTypes.Name)</span>
            <form method="post" action="/logout">
                <button type="submit" class="ghost-button" title="Sign out">Sign out</button>
            </form>
        }
        else
        {
            <a class="login-button" href="/login" title="Sign in with Kick">Sign in</a>
        }
    </nav>
</header>
